{
  "name": "iobroker.mihome-vacuum-ai",
  "version": "5.3.1-alpha.5",
  "description": "Control your mihome vacuum cleaner with ioBroker (AI test fork with Dreame/X20 Max support)",
  "keywords": [
    "dreame",
    "ioBroker",
    "mihome-vacuum",
    "mihome-vacuum-ai",
    "xiaomi"
  ],
  "homepage": "https://github.com/di3t0/ioBroker.mihome-vacuum-ai",
  "bugs": {
    "url": "https://github.com/di3t0/ioBroker.mihome-vacuum-ai/issues"
  },
  "license": "MIT",
  "author": {
    "name": "bluefox",
    "email": "dogafox@gmail.com"
  },
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/di3t0/ioBroker.mihome-vacuum-ai"
  },
  "scripts": {
    "test:js": "mocha --config test/mocha.custom.json \"{!(node_modules|test)/**/*.test.js,*.test.js,test/**/test!(PackageFiles|Startup).js}\"",
    "test:package": "mocha test/package --exit",
    "test:unit": "mocha test/unit --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:js && npm run test:package",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint -c eslint.config.mjs .",
    "translate": "gulp translateAndUpdateWordsJS",
    "release": "release-script"
  },
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*).json",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "lib/",
    "www/",
    "io-package.json",
    "LICENSE",
    "main.js"
  ],
  "optionalDependencies": {
    "canvas": "^3.1.2"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.2.3",
    "qs": "^6.14.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^3.8.0",
    "@alcalzone/release-script-plugin-iobroker": "^3.7.2",
    "@alcalzone/release-script-plugin-license": "^3.7.0",
    "@alcalzone/release-script-plugin-manual-review": "^3.7.0",
    "@iobroker/eslint-config": "^2.0.2",
    "@iobroker/testing": "^5.0.4",
    "@types/chai": "^5.2.2",
    "@types/chai-as-promised": "^8.0.2",
    "@types/gulp": "^4.0.17",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.8",
    "@types/proxyquire": "^1.3.31",
    "@types/sinon": "^17.0.3",
    "@types/sinon-chai": "^4.0.0",
    "axios": "^1.11.0",
    "chai": "^5.1.2",
    "chai-as-promised": "^8.0.1",
    "gulp": "^5.0.1",
    "mocha": "^11.7.1",
    "proxyquire": "^2.1.3",
    "sinon": "^21.0.0",
    "sinon-chai": "^4.0.0",
    "typescript": "^5.8.3"
  }
}
